    {
      "request": {
        "method": "PUT",
        "url": "AccessPolicy/developer-api-grant"
      },
      "resource": {
        "resourceType": "AccessPolicy",
        "id": "developer-api-grant",
        "engine": "matcho",
        "matcho": {
          "client": {
            "id": "developer-api"
          },
          "request-method": {
            "$one-of": [
              "get",
              "post",
              "put",
              "patch",
              "delete"
            ]
          },
          "uri": {
            "$one-of": [
